# ------------------------------------------------------------
# Torque Group — environment variables
# Copy this file to `.env.local` and fill in real values.
# Add the same values in the Vercel dashboard for production.
# Never commit `.env.local`.
# ------------------------------------------------------------

# ---- Site --------------------------------------------------
# Absolute URL of the deployed site (no trailing slash).
# Used for canonical URLs, sitemap entries, JSON-LD, OG tags.
NEXT_PUBLIC_SITE_URL=https://torquegroupcompanies.com

# ---- Brevo (transactional email) ---------------------------
# Sign up at https://www.brevo.com  (free: 300/day = ~9k/month).
# Dashboard -> SMTP & API -> API keys -> Generate a new API key.
BREVO_API_KEY=

# Sender shown to recipients. The "email" must be on a Brevo-
# verified sender or domain. For testing without a verified
# domain, add a sender at Brevo > Senders & IPs > Senders and
# verify via the email link they send.
MAIL_FROM_EMAIL=noreply@torquegroup.com
MAIL_FROM_NAME="Torque Group"

# Group desk — CC on every routed inquiry + fallback contact.
MAIL_GROUP=sepl@subhagmail.com

# Per-company destination inboxes. Swap any of these in the
# Vercel dashboard to redirect inquiries — no code redeploy.
MAIL_INSTITUTE=pune@torquetechnic.com
MAIL_CHENNAI=info@torquetechnics.com
MAIL_SUBHAGS=sepl@subhagmail.com
MAIL_NULITE=mail@nulite.co.in
MAIL_WOLFF=awllp@awllpindia.com

# ---- reCAPTCHA v2 invisible --------------------------------
# Sign up at https://www.google.com/recaptcha/admin
# Create a v2 "Invisible reCAPTCHA badge" key. Add your domains
# (e.g. torquegroup.com, localhost). Paste the Site Key + Secret.
# If left blank, the form skips reCAPTCHA entirely (dev mode).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ---- Analytics ---------------------------------------------
# Vercel Analytics is built-in. No env var needed — just enable
# Analytics in the Vercel project dashboard after deployment.
