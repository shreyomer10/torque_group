# ------------------------------------------------------------
# Torque Group — environment variables
# Copy this file to `.env.local` and fill in real values.
# Add the same values in the Vercel dashboard for production.
# Never commit `.env.local`.
# ------------------------------------------------------------

# ---- Site --------------------------------------------------
# Absolute URL of the deployed site (no trailing slash).
# Used for canonical URLs, sitemap entries, JSON-LD, OG tags.
NEXT_PUBLIC_SITE_URL=https://torquegroup.com

# ---- Resend (transactional email) --------------------------
# Sign up at https://resend.com, verify torquegroup.com (3 DNS records),
# create an API key.
RESEND_API_KEY=

# Sender shown to recipients. Must be on a Resend-verified domain.
MAIL_FROM="Torque Group <noreply@torquegroup.com>"

# Group desk — CC on every routed inquiry + fallback contact.
MAIL_GROUP=group@torquegroup.com

# Per-company destination inboxes. Swap any of these in the Vercel
# dashboard to redirect inquiries — no code redeploy required.
MAIL_INSTITUTE=admissions@torquetechnicsinstitute.com
MAIL_CHENNAI=service@torquetechnics.com
MAIL_SUBHAGS=sales@subhags.com
MAIL_NULITE=safety@nulite.in
MAIL_WOLFF=info@armaturen-wolff.de

# ---- Analytics ---------------------------------------------
# Vercel Analytics is built-in. No setup needed beyond deploying
# to Vercel and enabling Analytics in the project dashboard.
